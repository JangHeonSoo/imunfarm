---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/FormattedDate'
import BaseLayout from '@/layouts/BaseLayout'
import Tag from '@/components/Tag'
import type { MarkdownHeading } from 'astro'
import { siteConfig } from '@/site-config'

type Props = {
	id: CollectionEntry<'blog'>['id']
	data: CollectionEntry<'blog'>['data']
	headings: MarkdownHeading[]
	readTime: string
}

const { data, readTime, headings, id } = Astro.props
const { title, description, pubDate, heroImage, tags } = data

const articleDate = pubDate.toISOString()
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href
const heroImageURL = heroImage ? new URL(heroImage.src, Astro.site).href : undefined

// Article JSON-LD
const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	image: heroImageURL,
	datePublished: articleDate,
	dateModified: articleDate,
	author: {
		'@type': 'Organization',
		name: siteConfig.author.name,
		url: siteConfig.siteUrl
	},
	publisher: {
		'@type': 'Organization',
		name: siteConfig.author.name,
		url: siteConfig.siteUrl
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalURL
	},
	keywords: tags.join(', ')
}

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: siteConfig.siteUrl
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Blog',
			item: `${siteConfig.siteUrl}blog/`
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title
		}
	]
}
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage?.src}
	articleDate={articleDate}
	postSlug={data.slug ||
		id
			.split('/')
			.pop()
			?.replace(/\.(mdx|md)$/, '')}
	postCategory={data.category}
>
	<!-- JSON-LD Structured Data -->
	<script type='application/ld+json' set:html={JSON.stringify(articleSchema)} />
	<script type='application/ld+json' set:html={JSON.stringify(breadcrumbSchema)} />

	<article class='article-shell min-w-full sm:max-w-none md:max-w-none'>
		<header class='article-hero mb-3 flex flex-col justify-center items-center gap-6'>
			<div class='flex flex-col gap-2'>
				<div class='article-meta-pill'>
					<p>
						IMUN.FARM &middot; Published: <FormattedDate date={pubDate} />
					</p>
					<p>- 읽는 시간: {readTime}</p>
				</div>
				<h1 class='article-title'>
					{title}
				</h1>
			</div>

			<div class='flex flex-wrap justify-center items-center gap-2 gap-y-4 md:gap-5'>
				{tags.map((tag) => <Tag tag={tag} />)}
			</div>
		</header>

		<hr class='article-divider' />

		<div>
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.article-shell {
		position: relative;
		z-index: 1;
		width: min(1180px, calc(100vw - 48px));
		margin: 0 auto;
		padding: clamp(7rem, 11vw, 11rem) 0 3rem;
	}

	.article-hero {
		border: 1px solid rgba(246, 247, 251, 0.1);
		border-radius: 2rem;
		padding: clamp(2rem, 5vw, 5rem);
		background: rgba(246, 247, 251, 0.045);
		box-shadow: 0 32px 100px rgba(0, 0, 0, 0.18);
		backdrop-filter: blur(4px);
	}

	.article-meta-pill {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		width: max-content;
		max-width: 100%;
		margin: 0 auto 1.4rem;
		border: 1px solid rgba(106, 228, 255, 0.22);
		border-radius: 999px;
		background: rgba(106, 228, 255, 0.08);
		color: #6ae4ff;
		padding: 0.6rem 0.95rem;
	}

	.article-meta-pill p {
		margin: 0;
		font-size: 13px;
		font-weight: 760;
	}

	.article-title {
		max-width: 1040px;
		margin: 0 auto;
		text-align: center;
		color: #f6f7fb;
		font-size: clamp(3rem, 7vw, 7.4rem);
		font-weight: 860;
		line-height: 0.95;
		letter-spacing: -0.08em;
		text-wrap: balance;
	}

	.article-divider {
		margin: clamp(2rem, 5vw, 4rem) 0;
		border-color: rgba(246, 247, 251, 0.1);
	}

	:global(.article-shell .prose) {
		max-width: none;
		color: rgba(246, 247, 251, 0.72) !important;
		font-size: clamp(18px, 1.6vw, 21px);
		line-height: 1.8;
	}

	:global(.article-shell .prose h1),
	:global(.article-shell .prose h2),
	:global(.article-shell .prose h3),
	:global(.article-shell .prose h4),
	:global(.article-shell .prose h5),
	:global(.article-shell .prose h6) {
		color: #f6f7fb !important;
		letter-spacing: -0.055em;
		line-height: 1.05;
	}

	:global(.article-shell .prose h1) {
		font-size: clamp(2.4rem, 5vw, 5rem);
	}

	:global(.article-shell .prose h2) {
		margin-top: 4rem;
		font-size: clamp(2rem, 4vw, 4rem);
	}

	:global(.article-shell .prose p),
	:global(.article-shell .prose li) {
		color: rgba(246, 247, 251, 0.68) !important;
	}

	:global(.article-shell .prose strong) {
		color: #f6f7fb !important;
	}

	:global(.article-shell .prose a) {
		color: #6ae4ff !important;
		text-decoration-color: rgba(106, 228, 255, 0.35);
	}

	:global(.article-shell .prose blockquote) {
		border-left-color: #6ae4ff;
		background: rgba(246, 247, 251, 0.045);
		border-radius: 0 18px 18px 0;
		padding: 1rem 1.25rem;
	}

	:global(.article-shell .prose table) {
		border-radius: 18px;
		overflow: hidden;
		background: rgba(246, 247, 251, 0.045);
	}

	:global(.article-shell .prose img) {
		border-radius: 1.5rem;
		border: 1px solid rgba(246, 247, 251, 0.1);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.25);
	}

	:global(.article-shell footer h2) {
		color: #f6f7fb !important;
	}
</style>

<script src='https://platform.twitter.com/widgets.js' async></script>
<script>
	const fnObserver = () => {
		function handleIntersection(
			entries: IntersectionObserverEntry[],
			observer: IntersectionObserver
		) {
			entries.forEach((entry) => {
				const index = document.querySelector(`aside a[href="#${entry.target.id}"]`)

				if (entry.isIntersecting) {
					index?.classList.add(
						'text-[#6ae4ff]',
						'border-[#6ae4ff]/40',
						'bg-white/[0.07]',
						'font-bold'
					)
				} else {
					index?.classList.remove(
						'text-[#6ae4ff]',
						'border-[#6ae4ff]/40',
						'bg-white/[0.07]',
						'font-bold'
					)
				}
			})
		}

		const headings = document.querySelectorAll(
			'div.prose h1, div.prose h2, div.prose h3, div.prose h4, div.prose h5, div.prose h6'
		)

		const options = {
			root: null,
			rootMargin: ' 15% 0px 0% 0px ',
			threshold: 1
		}

		const observer = new IntersectionObserver(handleIntersection, options)

		headings.forEach((heading) => {
			observer.observe(heading)
		})
	}
	fnObserver()
	document.addEventListener('astro:after-swap', fnObserver)
</script>
