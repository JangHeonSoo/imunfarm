---
import type { CollectionEntry } from 'astro:content'

import { cn, getPostUrl, DEFAULT_LOCALE } from '@/utils'

type Props = {
	posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
---

<section class={cn(`grid gap-4 md:grid-cols-3`)}>
	{
		posts.length > 0 ? (
			posts.map((post, index) => {
				return (
					<a
						class='group flex min-h-36 min-w-0 flex-col justify-between rounded-2xl border border-white/12 bg-white/[0.045] p-5 transition-all hover:-translate-y-1 hover:border-[#6ae4ff]/35 hover:bg-white/[0.07]'
						href={getPostUrl(post.slug, currentLocale, post.data.category)}
					>
						<span class='text-sm font-bold text-[#6ae4ff]'>0{index + 1}</span>
						<header class='mt-8 min-w-0'>
							<p class='line-clamp-3 font-semibold leading-snug text-[#f6f7fb] transition-colors group-hover:text-[#6ae4ff]'>
								{post.data.title}
							</p>
						</header>
					</a>
				)
			})
		) : (
			<span class='text-[#f6f7fb]/50'>There are no related posts yet.</span>
		)
	}
</section>
