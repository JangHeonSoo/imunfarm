---
import type { CollectionEntry } from 'astro:content'

import { cn, getCategoryName, sluglify, getPostUrl, DEFAULT_LOCALE } from '@/utils'
import { Image } from 'astro:assets'

type Props = {
	posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
---

<section class={cn(`grid gap-4 md:grid-cols-3`)}>
	{
		posts.length > 0 ? (
			posts.map((post) => {
				const categorySlug = sluglify(getCategoryName(post.data.category).toLowerCase())
				return (
					<div class='flex min-w-0 items-center gap-3 rounded-2xl border border-white/12 bg-white/[0.045] p-4'>
						{post.data.heroImage ? (
							<div class='shrink-0'>
								<Image
									src={post.data.heroImage}
									width={200}
									height={200}
									format='webp'
									class='h-16 w-16 rounded-full object-cover'
									alt={`img of ${post.data.title}`}
								/>
							</div>
						) : null}
						<header class='min-w-0 flex-1'>
							<a
								class='block font-medium leading-snug text-[#f2f4ea] hover:text-[#d8ff4f]'
								href={getPostUrl(post.slug, currentLocale, post.data.category)}
							>
								{post.data.title}
							</a>
						</header>
					</div>
				)
			})
		) : (
			<span class='text-[#f2f4ea]/50'>There are no related posts yet.</span>
		)
	}
</section>
