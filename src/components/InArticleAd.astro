---
/**
 * In-Article AdSense Ad Component
 * Automatically injected into blog post content via client-side script.
 * This component renders the ad unit markup.
 */
---

<div class='in-article-ad-container my-8'>
	<ins
		class='adsbygoogle'
		style='display:block'
		data-ad-client='ca-pub-9192660979184684'
		data-ad-slot='3171759407'
		data-ad-format='auto'
		data-full-width-responsive='true'></ins>
</div>
