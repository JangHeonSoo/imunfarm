---
import BaseLayout from '@/layouts/BaseLayout'
import { DEFAULT_LOCALE, getLocalePrefix, getPosts, getPostUrl } from '@/utils'

const { locale = DEFAULT_LOCALE } = Astro.props
const MAX_POSTS = 6
const isEn = locale === 'en'
const localePrefix = getLocalePrefix(locale)
const dateLocale = isEn ? 'en-US' : 'ko-KR'
const allPosts = await getPosts(undefined, locale)
const posts = allPosts.slice(0, MAX_POSTS)
const postCount = allPosts.length
---

<BaseLayout title='Home' fullBleed={true}>
	<div class='agri-home'>
		<canvas id='agri-field' aria-hidden='true'></canvas>
		<div class='grain' aria-hidden='true'></div>

		<section class='hero'>
			<div class='hero-topline'>
				<p class='kicker'>
					{
						isEn ? (
							<>
								<strong>Agrivoltaics and smart farm operations</strong> explained through policy,
								cost, profitability, and field technology.
							</>
						) : (
							<>
								<strong>영농형 태양광과 스마트팜 운영</strong>에 필요한 정책, 비용, 수익성, 기술
								정보를 현장 관점으로 정리합니다.
							</>
						)
					}
				</p>
				<div class='status'>
					<span class='status-pill'><i></i> agrivoltaics guide</span>
					<span>Policy / Cost / AI Farming</span>
				</div>
			</div>

			<h1 class='headline' aria-label='Farm Energy Intelligence'>
				<span>Farm</span>
				<span class='outline'>Energy</span>
				<span class='glow'>Intelligence</span>
			</h1>

			<div class='hero-panel'>
				<article class='intro-card'>
					<p>
						{
							isEn
								? 'Clear notes on farmland use, solar permits, smart farm automation, and AI farming tools.'
								: '농지 활용, 태양광 인허가, 스마트팜 자동화, AI 농업 도구를 실무자가 빠르게 비교할 수 있게 기록합니다.'
						}
					</p>
					<span class='num'>01</span>
				</article>
				<article class='metric-card'>
					<span class='metric-label'>published posts</span>
					<div class='metric-value'><span id='field-metric'>{postCount}</span></div>
					<div class='scanline'></div>
				</article>
			</div>
		</section>

		<div class='ticker' aria-hidden='true'>
			<div class='ticker-track'>
				<span><b>SOLAR</b> intake</span><span>crop growth</span><span><b>AI</b> agents</span><span
					>market signal</span
				><span>field records</span><span><b>DATA</b> loop</span>
				<span><b>SOLAR</b> intake</span><span>crop growth</span><span><b>AI</b> agents</span><span
					>market signal</span
				><span>field records</span><span><b>DATA</b> loop</span>
			</div>
		</div>

		<section id='stories' class='reveal'>
			<div class='section-head'>
				<span class='eyebrow'>Stories</span>
				<h2 class='section-title'>{isEn ? 'Latest Field Notes' : '이문농장 기록'}</h2>
			</div>
			<div class='story-stream' aria-label={isEn ? 'Recent posts' : '최근 포스팅'}>
				{
					posts.map((post, index) => (
						<article class='post-card story-card reveal' style={`--story-index:${index + 1}`}>
							{post.data.heroImage && <img src={post.data.heroImage} alt={post.data.title} />}
							<div>
								<time>
									{post.data.pubDate?.toLocaleDateString(dateLocale, {
										year: 'numeric',
										month: 'long',
										day: 'numeric'
									})}
								</time>
								<h3>
									<a href={getPostUrl(post.slug, locale, post.data.category)}>{post.data.title}</a>
								</h3>
								<p>{post.data.description}</p>
								<a class='story-link' href={getPostUrl(post.slug, locale, post.data.category)}>
									Read Article
								</a>
							</div>
						</article>
					))
				}
			</div>
			<a class='section-cta story-archive-link' href={`${localePrefix}/blog`}>View Post</a>
		</section>
	</div>
</BaseLayout>

<script>
	const root = document.documentElement
	const metric = document.getElementById('field-metric')
	const canvas = document.getElementById('agri-field') as HTMLCanvasElement | null
	const ctx = canvas?.getContext('2d')
	let pointer = { x: window.innerWidth / 2, y: window.innerHeight / 2 }
	let particles: { x: number; y: number; vx: number; vy: number; r: number; c: string }[] = []

	window.addEventListener('pointermove', (event) => {
		pointer = { x: event.clientX, y: event.clientY }
		root.style.setProperty('--mx', `${pointer.x}px`)
		root.style.setProperty('--my', `${pointer.y}px`)
		if (metric) {
			metric.textContent = String(metric.dataset.count ?? metric.textContent)
		}
	})

	function resizeField() {
		if (!canvas || !ctx) return
		const dpr = Math.min(window.devicePixelRatio || 1, 2)
		canvas.width = Math.floor(window.innerWidth * dpr)
		canvas.height = Math.floor(window.innerHeight * dpr)
		canvas.style.width = `${window.innerWidth}px`
		canvas.style.height = `${window.innerHeight}px`
		ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
		const count = Math.floor(Math.min(96, Math.max(44, window.innerWidth / 18)))
		const colors = ['216,255,79', '124,247,255', '255,179,92']
		particles = Array.from({ length: count }, (_, index) => ({
			x: Math.random() * window.innerWidth,
			y: Math.random() * window.innerHeight,
			vx: (Math.random() - 0.5) * 0.28,
			vy: (Math.random() - 0.5) * 0.28,
			r: Math.random() * 1.7 + 0.5,
			c: colors[index % colors.length]
		}))
	}

	function drawField() {
		if (!ctx) return
		ctx.clearRect(0, 0, window.innerWidth, window.innerHeight)
		for (const particle of particles) {
			const dx = pointer.x - particle.x
			const dy = pointer.y - particle.y
			const dist = Math.hypot(dx, dy)
			const force = Math.max(0, 1 - dist / 280)
			particle.x += particle.vx - dx * force * 0.002
			particle.y += particle.vy - dy * force * 0.002
			if (particle.x < -24) particle.x = window.innerWidth + 24
			if (particle.x > window.innerWidth + 24) particle.x = -24
			if (particle.y < -24) particle.y = window.innerHeight + 24
			if (particle.y > window.innerHeight + 24) particle.y = -24
			ctx.beginPath()
			ctx.fillStyle = `rgba(${particle.c}, ${0.24 + force * 0.42})`
			ctx.arc(particle.x, particle.y, particle.r + force * 2, 0, Math.PI * 2)
			ctx.fill()
		}
		requestAnimationFrame(drawField)
	}

	const io = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) entry.target.classList.add('visible')
			}
		},
		{ threshold: 0.14 }
	)
	document.querySelectorAll('.reveal').forEach((el) => io.observe(el))
	resizeField()
	drawField()
	window.addEventListener('resize', resizeField)
</script>

<style>
	:global(html) {
		scroll-behavior: smooth;
	}

	.agri-home {
		--bg: #070807;
		--panel: rgba(255, 255, 255, 0.07);
		--panel-strong: rgba(255, 255, 255, 0.12);
		--line: rgba(255, 255, 255, 0.15);
		--text: #f2f4ea;
		--muted: rgba(242, 244, 234, 0.64);
		--dim: rgba(242, 244, 234, 0.34);
		--acid: #d8ff4f;
		--lime: #b8ff7a;
		--cyan: #7cf7ff;
		--orange: #ffb35c;
		--pink: #ff7ad9;
		--mx: 50vw;
		--my: 50vh;
		position: relative;
		width: 100%;
		min-height: 100vh;
		color: var(--text);
		background:
			linear-gradient(120deg, rgba(216, 255, 79, 0.09), transparent 34%),
			linear-gradient(210deg, rgba(124, 247, 255, 0.08), transparent 30%), #070807;
		font-family:
			Inter,
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			'Noto Sans KR',
			sans-serif;
		overflow-x: hidden;
	}

	.agri-home::before {
		content: '';
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: radial-gradient(circle at var(--mx) var(--my), black 0 34rem, transparent 56rem);
		opacity: 0.42;
	}

	#agri-field {
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		opacity: 0.78;
	}

	.grain {
		position: fixed;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		opacity: 0.06;
		background-image: radial-gradient(circle, #fff 0 1px, transparent 1.5px);
		background-size: 170px 130px;
		mix-blend-mode: overlay;
	}

	.nav,
	.hero,
	.ticker,
	.agri-home section {
		position: relative;
		z-index: 2;
	}

	.nav {
		position: fixed;
		left: 50%;
		top: 18px;
		z-index: 10;
		width: min(1720px, calc(100vw - 36px));
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 16px;
		padding: 12px 14px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		background: rgba(7, 8, 7, 0.58);
		backdrop-filter: blur(18px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 148px;
		margin-right: auto;
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.brand-mark {
		width: 34px;
		height: 34px;
		border-radius: 50%;
		background: conic-gradient(
			from 180deg,
			var(--acid),
			var(--cyan),
			var(--pink),
			var(--orange),
			var(--acid)
		);
		box-shadow: 0 0 42px rgba(216, 255, 79, 0.34);
	}

	.nav-links {
		display: flex;
		margin-left: auto;
		gap: 6px;
		color: rgba(242, 244, 234, 0.72);
		font-size: 12px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.nav-tools {
		display: flex;
		align-items: center;
		gap: 10px;
		color: rgba(242, 244, 234, 0.7);
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
	}

	.nav-tools a {
		transition: color 0.25s ease;
	}

	.nav-tools a:hover,
	.nav-tools a.active {
		color: var(--acid);
	}

	.nav-tools :global(site-search) {
		margin-left: 4px;
	}

	.nav-tools :global(site-search button) {
		width: 36px;
		height: 36px;
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 999px;
		color: var(--text);
		background: rgba(255, 255, 255, 0.06);
	}

	.nav-links a,
	.nav-cta {
		border-radius: 999px;
		padding: 10px 12px;
		transition:
			background 0.25s ease,
			color 0.25s ease;
	}

	.nav-links a:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.08);
	}

	.nav-cta {
		color: #080907;
		background: var(--acid);
		font-size: 12px;
		font-weight: 800;
	}

	.hero,
	.agri-home section {
		width: min(1720px, calc(100vw - 36px));
		margin: 0 auto;
	}

	.hero {
		min-height: 100vh;
		display: grid;
		align-items: end;
		padding: 134px 0 34px;
	}

	.hero-topline,
	.section-head {
		display: grid;
		grid-template-columns: 0.75fr 1.25fr;
		gap: 30px;
		align-items: end;
	}

	.hero-topline {
		margin-bottom: clamp(34px, 7vw, 90px);
	}

	.kicker {
		margin: 0;
		max-width: 600px;
		color: var(--muted);
		font-size: clamp(14px, 1.2vw, 18px);
		line-height: 1.72;
		word-break: keep-all;
	}

	.kicker strong {
		color: var(--text);
		font-weight: 700;
	}

	.status {
		display: grid;
		gap: 10px;
		justify-items: end;
		color: var(--muted);
		font-size: 12px;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.status-pill {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		padding: 10px 13px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.055);
	}

	.status-pill i {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--acid);
		box-shadow: 0 0 0 0 rgba(216, 255, 79, 0.72);
		animation: pulse 1.6s infinite;
	}

	@keyframes pulse {
		70% {
			box-shadow: 0 0 0 14px rgba(216, 255, 79, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(216, 255, 79, 0);
		}
	}

	.headline {
		margin: 0;
		font-size: clamp(54px, 12.8vw, 218px);
		line-height: 0.78;
		letter-spacing: -0.105em;
		font-weight: 900;
		text-transform: uppercase;
	}

	.headline span {
		display: block;
		width: max-content;
		max-width: 100%;
		animation: rise 0.9s cubic-bezier(0.19, 1, 0.22, 1) both;
	}

	.headline span:nth-child(2) {
		margin-left: clamp(0px, 7vw, 120px);
		animation-delay: 0.1s;
	}

	.headline span:nth-child(3) {
		animation-delay: 0.2s;
	}

	.outline {
		color: transparent;
		-webkit-text-stroke: 1.4px rgba(242, 244, 234, 0.7);
	}

	.glow {
		color: var(--acid);
		text-shadow: 0 0 55px rgba(216, 255, 79, 0.22);
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(34px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hero-panel {
		margin-top: 28px;
		display: grid;
		grid-template-columns: 1.25fr 0.75fr;
		gap: 14px;
	}

	.intro-card,
	.metric-card,
	.signal-card,
	.flow-wrap,
	.featured-post,
	.post-card,
	.ideas-band {
		border: 1px solid rgba(255, 255, 255, 0.13);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.032));
		backdrop-filter: blur(14px);
		box-shadow: 0 28px 90px rgba(0, 0, 0, 0.2);
	}

	.intro-card {
		min-height: 184px;
		border-radius: 28px;
		padding: 28px;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 24px;
		align-items: end;
	}

	.intro-card p {
		margin: 0;
		max-width: 800px;
		color: rgba(242, 244, 234, 0.76);
		font-size: clamp(17px, 2vw, 28px);
		line-height: 1.32;
		letter-spacing: -0.045em;
		word-break: keep-all;
	}

	.num {
		font-size: clamp(48px, 8vw, 108px);
		line-height: 0.82;
		letter-spacing: -0.09em;
		color: rgba(242, 244, 234, 0.16);
		font-weight: 900;
	}

	.metric-card {
		min-height: 184px;
		border-radius: 28px;
		padding: 22px;
		display: grid;
		align-content: space-between;
	}

	.metric-label,
	.eyebrow,
	.signal-label {
		color: var(--muted);
		font-size: 12px;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.metric-value {
		display: flex;
		align-items: end;
		gap: 9px;
		font-size: clamp(52px, 7vw, 102px);
		line-height: 0.82;
		letter-spacing: -0.08em;
		font-weight: 900;
	}

	.metric-value small {
		padding-bottom: 7px;
		color: var(--muted);
		font-size: 15px;
		letter-spacing: 0;
	}

	.scanline {
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--acid), var(--cyan), transparent);
		animation: scan 2.8s ease-in-out infinite;
	}

	@keyframes scan {
		0%,
		100% {
			transform: translateX(-32%);
			opacity: 0.35;
		}
		50% {
			transform: translateX(32%);
			opacity: 0.9;
		}
	}

	.ticker {
		width: 100%;
		border-block: 1px solid rgba(255, 255, 255, 0.11);
		overflow: hidden;
		background: rgba(255, 255, 255, 0.035);
	}

	.ticker-track {
		display: flex;
		width: max-content;
		animation: marquee 24s linear infinite;
	}

	.ticker span {
		padding: 20px 28px;
		color: rgba(242, 244, 234, 0.88);
		font-size: clamp(18px, 2vw, 30px);
		letter-spacing: -0.05em;
		white-space: nowrap;
	}

	.ticker b {
		color: var(--acid);
	}

	@keyframes marquee {
		to {
			transform: translateX(-50%);
		}
	}

	.agri-home section {
		padding: clamp(82px, 12vw, 160px) 0;
	}

	.section-head {
		align-items: start;
		margin-bottom: 36px;
	}

	#stories .section-head {
		grid-template-columns: auto 1fr;
		align-items: center;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
	}

	.eyebrow::before {
		content: '';
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--acid);
	}

	.section-title {
		margin: 0;
		font-size: clamp(38px, 6vw, 92px);
		line-height: 0.93;
		letter-spacing: -0.075em;
		font-weight: 900;
		word-break: keep-all;
	}

	.section-title span {
		color: rgba(242, 244, 234, 0.34);
	}

	.section-cta {
		justify-self: end;
		width: max-content;
		color: #080907;
		background: var(--acid);
		border-radius: 999px;
		padding: 12px 16px;
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		transition:
			transform 0.25s ease,
			background 0.25s ease;
	}

	.section-cta:hover {
		transform: translateY(-2px);
		background: var(--cyan);
	}

	.signal-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		border-top: 1px solid rgba(255, 255, 255, 0.15);
	}

	.signal-card {
		position: relative;
		min-height: 390px;
		padding: 26px;
		border-radius: 0;
		border-left: 0;
		overflow: hidden;
	}

	.signal-card:first-child {
		border-left: 1px solid rgba(255, 255, 255, 0.13);
	}

	.signal-card strong {
		display: block;
		margin-top: 36px;
		font-size: clamp(48px, 5vw, 82px);
		line-height: 0.86;
		letter-spacing: -0.085em;
	}

	.signal-card p {
		position: absolute;
		left: 26px;
		right: 26px;
		bottom: 28px;
		margin: 0;
		color: rgba(242, 244, 234, 0.62);
		line-height: 1.6;
		word-break: keep-all;
	}

	.signal-card i {
		position: absolute;
		right: 24px;
		top: 24px;
		width: 112px;
		height: 112px;
		border-radius: 50%;
		border: 1px solid currentColor;
		opacity: 0.32;
	}

	.signal-card.lime {
		color: var(--acid);
	}
	.signal-card.mint {
		color: var(--lime);
	}
	.signal-card.cyan {
		color: var(--cyan);
	}
	.signal-card.amber {
		color: var(--orange);
	}

	.flow-wrap {
		position: relative;
		min-height: 760px;
		border-radius: 38px;
		overflow: hidden;
		display: grid;
		grid-template-columns: 1.08fr 0.92fr;
	}

	.flow-wrap::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.052) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.052) 1px, transparent 1px);
		background-size: 42px 42px;
		mask-image: radial-gradient(circle at 36% 50%, black 0 44%, transparent 76%);
		opacity: 0.38;
		pointer-events: none;
	}

	.control-map {
		position: relative;
		min-height: 760px;
		border-right: 1px solid rgba(255, 255, 255, 0.12);
		overflow: hidden;
	}

	.control-map::before {
		content: 'FIELD GRID';
		position: absolute;
		left: 30px;
		top: 26px;
		color: rgba(242, 244, 234, 0.38);
		font-size: 11px;
		letter-spacing: 0.18em;
		z-index: 2;
