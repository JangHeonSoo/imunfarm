---
import HeaderLink from '@/components/HeaderLink'
import MenuIcon from './icons/MenuIcon.astro'
import Search from '@/components/Search'
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, getLocalePrefix, getPostUrl } from '@/utils'

const { postSlug, postCategory } = Astro.props

const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const localePrefix = getLocalePrefix(currentLocale)
const currentPath = Astro.url.pathname

const buildLocalePath = (targetLocale: string) => {
	// If we have explicit post info, use getPostUrl for precise mapping
	if (postSlug) {
		return getPostUrl(postSlug, targetLocale, postCategory)
	}

	const segments = currentPath.split('/').filter(Boolean)
	const hasLocalePrefix = SUPPORTED_LOCALES.includes(segments[0] as any)
	const rest = hasLocalePrefix ? segments.slice(1) : segments

	if (rest.length === 0) {
		return buildHomePath(targetLocale)
	}

	// Prevent /ko prefix if not wanted, but keep others
	const effectivePrefix = targetLocale === DEFAULT_LOCALE ? '' : `/${targetLocale}`

	// Handle Tags mapping
	if (rest[0] === 'tags') {
		return `${effectivePrefix}/${rest.join('/').toLowerCase()}`
	}

	const newPath = `/${[targetLocale, ...rest].join('/')}`
	return newPath.replace(/\/ko\//, '/').replace(/\/ko$/, '/')
}
const buildHomePath = (targetLocale: string) => {
	return targetLocale === DEFAULT_LOCALE ? '/' : `/${targetLocale}/`
}
---

<header
	class='fixed left-1/2 top-[18px] z-50 w-[min(1720px,calc(100vw-36px))] -translate-x-1/2 rounded-full border border-white/15 bg-[#070807]/60 px-[14px] py-3 shadow-[0_24px_80px_rgba(0,0,0,0.28)] backdrop-blur-xl'
>
	<div class='grid w-full grid-cols-[auto_1fr] items-center gap-4'>
		<a
			class='flex min-w-[148px] items-center gap-3 text-base font-extrabold tracking-[-0.04em] text-[#f2f4ea]'
			href={buildHomePath(currentLocale)}
		>
			<span
				class='h-9 w-9 rounded-full bg-[conic-gradient(from_180deg,#d8ff4f,#7cf7ff,#ff7ad9,#ffb35c,#d8ff4f)] shadow-[0_0_42px_rgba(216,255,79,0.34)]'
			></span>
			<span>IMUN.FARM</span>
		</a>

		<div class='ml-auto flex min-w-0 items-center justify-end gap-2'>
			<nav
				class='hidden min-w-0 items-center justify-end gap-2 text-xs uppercase tracking-[0.12em] text-[#f2f4ea]/70 md:flex'
			>
				<HeaderLink
					href={`${localePrefix}/blog`}
					class='rounded-full px-3 py-2 font-medium transition-colors hover:bg-white/10 hover:text-[#f2f4ea]'
				>
					{currentLocale === 'en' ? 'Blog' : '블로그'}
				</HeaderLink>
				<HeaderLink
					href={`${localePrefix}/about`}
					class='rounded-full px-3 py-2 font-medium transition-colors hover:bg-white/10 hover:text-[#f2f4ea]'
				>
					{currentLocale === 'en' ? 'About' : '소개'}
				</HeaderLink>
				<HeaderLink
					href={`${localePrefix}/contact`}
					class='rounded-full px-3 py-2 font-medium transition-colors hover:bg-white/10 hover:text-[#f2f4ea]'
				>
					{currentLocale === 'en' ? 'Contact' : '협찬문의'}
				</HeaderLink>
				<HeaderLink
					href={`${localePrefix}/tags`}
					class='rounded-full px-3 py-2 font-medium transition-colors hover:bg-white/10 hover:text-[#f2f4ea]'
				>
					Tags
				</HeaderLink>
				<div class='flex items-center gap-2 pl-2 text-xs font-bold uppercase tracking-wider'>
					{
						SUPPORTED_LOCALES.map((locale: (typeof SUPPORTED_LOCALES)[number]) => (
							<a
								href={buildLocalePath(locale)}
								class={
									locale === currentLocale
										? 'text-[#d8ff4f]'
										: 'text-[#f2f4ea]/50 hover:text-[#d8ff4f]'
								}
							>
								{locale.toUpperCase()}
							</a>
						))
					}
				</div>
			</nav>
			<div class='flex items-center gap-2 text-xs font-bold uppercase tracking-wider md:hidden'>
				{
					SUPPORTED_LOCALES.map((locale: (typeof SUPPORTED_LOCALES)[number]) => (
						<a
							href={buildLocalePath(locale)}
							class={
								locale === currentLocale
									? 'text-[#d8ff4f]'
									: 'text-[#f2f4ea]/50 hover:text-[#d8ff4f]'
							}
						>
							{locale.toUpperCase()}
						</a>
					))
				}
			</div>
			<Search />
			<button
				id='astro-header-drawer-button'
				type='button'
				class='rounded-full border border-white/15 p-2 text-[#f2f4ea] md:hidden'
			>
				<MenuIcon />
				<span class='sr-only'>Show Menu</span>
			</button>
		</div>
	</div>
</header>

<!-- Mobile Menu -->
<div
	id='astro-header-drawer'
	class='md:hidden fixed top-24 right-4 z-40 h-auto w-72 rounded-3xl border border-white/15 bg-[#070807]/95 shadow-xl backdrop-blur-xl transform translate-x-[120%] transition-transform duration-300'
>
	<nav class='flex flex-col items-end p-6 gap-4 text-right text-[#f2f4ea]'>
		<HeaderLink href={`${localePrefix}/blog`} class='text-lg'>
			{currentLocale === 'en' ? 'Blog' : '블로그'}
		</HeaderLink>
		<HeaderLink href={`${localePrefix}/about`} class='text-lg opacity-70'>
			{currentLocale === 'en' ? 'About' : '소개'}
		</HeaderLink>
		<HeaderLink href={`${localePrefix}/contact`} class='text-lg opacity-70'>
			{currentLocale === 'en' ? 'Contact' : '협찬문의'}
		</HeaderLink>
		<HeaderLink href={`${localePrefix}/tags`} class='text-lg opacity-70'>Tags</HeaderLink>
	</nav>
</div>

<script>
	function initMobileMenu() {
		const menu = document.getElementById('astro-header-drawer')
		const menuButton = document.getElementById('astro-header-drawer-button')

		if (!menu || !menuButton) return

		menuButton.addEventListener('click', (e) => {
			e.stopPropagation()
			menu.classList.toggle('translate-x-[120%]')
		})

		document.addEventListener('click', (event) => {
			const isClickInside =
				menu.contains(event.target as HTMLElement) ||
				menuButton.contains(event.target as HTMLElement)
			if (!isClickInside && !menu.classList.contains('translate-x-[120%]')) {
				menu.classList.add('translate-x-[120%]')
			}
		})

		const menuLinks = menu.querySelectorAll('a')
		menuLinks.forEach((link) => {
			link.addEventListener('click', () => {
				menu.classList.add('translate-x-[120%]')
			})
		})
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initMobileMenu)
	} else {
		initMobileMenu()
	}

	document.addEventListener('astro:page-load', initMobileMenu)
</script>
