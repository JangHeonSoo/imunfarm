---
import { Image } from 'astro:assets'
import {
	getCategoryName,
	getCategoryTitleFromSlug,
	sluglify,
	getPostUrl,
	DEFAULT_LOCALE
} from '@/utils'
import FormattedDate from '@/components/FormattedDate'
import ArrowUp from '@/components/icons/ArrowUp'

const {
	id,
	data: { title, description, pubDate, heroImage, category },
	readTime,
	slug,
	displayAsRows = false
} = Astro.props

const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const categorySlug = sluglify(getCategoryName(category).toLowerCase())
const categoryTitle = getCategoryTitleFromSlug(categorySlug, currentLocale)
const postUrl = getPostUrl(slug, currentLocale, category)
---

<article
	class='rounded-[26px] overflow-hidden border border-white/12 bg-white/[0.055] shadow-[0_24px_70px_rgba(0,0,0,0.18)] transition-all duration-300 hover:-translate-y-1 hover:border-[#d8ff4f]/35 hover:shadow-[0_30px_90px_rgba(0,0,0,0.28)] cursor-pointer group'
>
	{
		heroImage && (
			<a href={postUrl} class='relative block h-60 overflow-hidden'>
				<Image
					src={heroImage}
					width={600}
					height={240}
					format='webp'
					class='w-full h-full object-cover transition-transform duration-300 group-hover:scale-105'
					alt={`img of ${title}`}
				/>
				<span class='absolute top-5 left-5 border border-white/15 bg-[#070807]/80 text-[#f2f4ea] px-4 py-1.5 rounded-full text-sm font-semibold backdrop-blur'>
					{categoryTitle}
				</span>
			</a>
		)
	}

	<div class='p-8'>
		<span class='block text-sm text-[#f2f4ea]/50 mb-2.5'>
			<FormattedDate date={pubDate} />
		</span>

		<a href={postUrl}>
			<h3
				class='text-2xl font-heading font-semibold mb-4 text-[#f2f4ea] group-hover:text-[#d8ff4f] transition-colors'
			>
				{title}
			</h3>
		</a>

		<p class='text-base text-[#f2f4ea]/64 mb-5 line-clamp-3'>
			{description}
		</p>

		<a href={postUrl} class='inline-block text-[#d8ff4f] font-semibold transition-all hover:ml-1'>
			자세히 보기 →
		</a>
	</div>
</article>

<script>
	import { animate } from 'motion'

	const images = document.querySelectorAll('img')

	document.addEventListener('DOMContentLoaded', function () {
		const showAnimations = localStorage.getItem('animations') === 'true'

		if (showAnimations) {
			animate(
				'.effect',
				{
					opacity: [0, 1],
					clipPath: ['circle(0% at 0% 0%)', 'circle(100% at 50% 50%)']
				},
				{ duration: 2, easing: 'ease' }
			)
		} else {
			images.forEach((img) => {
				img.classList.remove('opacity-0')
			})
		}
	})
</script>
