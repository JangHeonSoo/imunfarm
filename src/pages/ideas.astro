---
import BaseLayout from '@/layouts/BaseLayout';
import IdeaTreeExperience from '@/components/IdeaTreeExperience';
import FadeIn from '../components/FadeIn.astro';

const SEO = {
  title: 'Community Ideas | IMUN.FARM',
  description: '독자들이 직접 제안하고 투표하는 IMUN.FARM 아이디어 나무. 가장 많은 표를 받은 아이디어는 블로그 포스트로 수확됩니다.',
};
---

<BaseLayout {...SEO}>
  {/* Immersive Fixed Background */}
  <div class="fixed inset-0 w-full h-full z-0 pointer-events-none">
    <img src="/images/ideas-hero-bg.png" alt="Digital Ideas Concept" class="w-full h-full object-cover opacity-80 mix-blend-luminosity dark:opacity-60" />
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/80 to-[#f8faf9] dark:from-gray-950/95 dark:via-gray-950/80 dark:to-gray-950"></div>
  </div>

  {/* Main Content */}
  <main class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 lg:px-12 pt-32 pb-40">

    {/* Hero Header */}
    <div class="text-center mb-8 max-w-4xl mx-auto mt-10 md:mt-20">
      <FadeIn direction="up">
        <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-primary/10 dark:bg-primary-light/10 text-primary dark:text-primary-light font-bold tracking-[0.2em] text-sm mb-8 border border-primary/20 backdrop-blur-md shadow-sm">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
          </span>
          IMUN.FARM COLLAB
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-black mb-8 tracking-tighter text-gray-900 dark:text-white leading-[1.1]">
          다음 수확은<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-blue-500 drop-shadow-sm">여러분이 결정합니다.</span>
        </h1>

        <p class="text-xl md:text-3xl text-gray-600 dark:text-gray-300 font-light leading-relaxed max-w-3xl mx-auto">
          공동의 아이디어가 기술을 만나 현실이 됩니다.<br class="hidden md:block"/>투표를 통해 다음 포스트를 직접 결정해 보세요.
        </p>
      </FadeIn>
    </div>

    {/* Idea Tree Experience */}
    <FadeIn delay={0.1} direction="up" className="w-full">
      <IdeaTreeExperience client:load />
    </FadeIn>

  </main>
</BaseLayout>
