---
import BaseLayout from '@/layouts/BaseLayout';
import SeedlingBoard from '@/components/SeedlingBoard';
import FadeIn from '../components/FadeIn.astro';

// 관리자가 선정한 아이디어 (public/data/selected-ideas.json)
let selectedIdeas: Array<{
  period: string
  ideaId: string
  title: string
  status: 'pending' | 'writing' | 'published'
  blogLink: string | null
}> = []

try {
  const { readFileSync } = await import('fs')
  const { join } = await import('path')
  const raw = readFileSync(join(process.cwd(), 'public/data/selected-ideas.json'), 'utf-8')
  selectedIdeas = JSON.parse(raw)
} catch { /* 파일 없으면 빈 배열 */ }

const statusConfig = {
  pending:   { label: '선정됨',   bg: 'bg-gray-50 dark:bg-gray-800/60',     text: 'text-gray-400 dark:text-gray-500',   border: 'border-gray-200 dark:border-gray-700' },
  writing:   { label: '작성 중',  bg: 'bg-amber-50 dark:bg-amber-900/10',    text: 'text-amber-600 dark:text-amber-400', border: 'border-amber-200 dark:border-amber-800' },
  published: { label: '게시 완료', bg: 'bg-emerald-50 dark:bg-emerald-900/10', text: 'text-emerald-600 dark:text-emerald-400', border: 'border-emerald-200 dark:border-emerald-800' },
}

const SEO = {
  title: 'Community Ideas | IMUN.FARM',
  description: '독자들이 직접 제안하고 투표하는 IMUN.FARM 아이디어 보드. 가장 많은 표를 받은 아이디어는 매주 블로그 포스트로 작성됩니다.',
};
---

<BaseLayout {...SEO}>
  {/* Immersive Fixed Background */}
  <div class="fixed inset-0 w-full h-full z-0 pointer-events-none">
    <img src="/images/ideas-hero-bg.png" alt="Digital Ideas Concept" class="w-full h-full object-cover opacity-80 mix-blend-luminosity dark:opacity-60" />
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/80 to-[#f8faf9] dark:from-gray-950/95 dark:via-gray-950/80 dark:to-gray-950"></div>
  </div>

  {/* Main Content */}
  <main class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 lg:px-12 pt-32 pb-40">

    {/* Hero Header */}
    <div class="text-center mb-24 max-w-4xl mx-auto mt-10 md:mt-20">
      <FadeIn direction="up">
        <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-primary/10 dark:bg-primary-light/10 text-primary dark:text-primary-light font-bold tracking-[0.2em] text-sm mb-8 border border-primary/20 backdrop-blur-md shadow-sm">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
          </span>
          IMUN.FARM COLLAB
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-black mb-8 tracking-tighter text-gray-900 dark:text-white leading-[1.1]">
          Building the Future,<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-blue-500 drop-shadow-sm">Together.</span>
        </h1>

        <p class="text-xl md:text-3xl text-gray-600 dark:text-gray-300 font-light leading-relaxed max-w-3xl mx-auto">
          공동의 아이디어가 기술을 만나 현실이 됩니다.<br class="hidden md:block"/>투표를 통해 다음 포스트를 직접 결정해 보세요.
        </p>
      </FadeIn>
    </div>

    {/* 선정된 아이디어 섹션 */}
    {selectedIdeas.length > 0 && (
      <FadeIn delay={0.1} direction="up" className="w-full mb-20">
        <div class="mb-8">
          <p class="text-xs font-bold tracking-[0.2em] uppercase text-primary mb-2">Selected</p>
          <h2 class="text-2xl md:text-3xl font-heading font-black text-gray-900 dark:text-white">선정된 아이디어</h2>
          <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">투표로 선정되어 작성 중이거나 완료된 아이디어입니다</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {selectedIdeas.map((item) => {
            const cfg = statusConfig[item.status] ?? statusConfig.pending
            return (
              <div class={`relative rounded-3xl border ${cfg.border} ${cfg.bg} p-6 flex flex-col gap-4 overflow-hidden transition-shadow hover:shadow-lg`}>
                {/* 기간 + 상태 */}
                <div class="flex items-center justify-between gap-2">
                  <span class="text-xs font-black tracking-widest uppercase text-primary">
                    {item.period}
                  </span>
                  <span class={`text-xs font-semibold ${cfg.text}`}>
                    {cfg.label}
                  </span>
                </div>

                {/* 제목 */}
                <p class="font-bold text-gray-900 dark:text-white leading-snug flex-1 text-sm">{item.title}</p>

                {/* 하단 액션 */}
                {item.status === 'published' && item.blogLink ? (
                  <a
                    href={item.blogLink}
                    class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline mt-auto"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    게시글 보러가기
                  </a>
                ) : item.status === 'writing' ? (
                  <p class="text-xs text-amber-500 dark:text-amber-400 font-medium mt-auto">현재 작성 중 — 곧 공개됩니다</p>
                ) : (
                  <p class="text-xs text-gray-400 font-medium mt-auto">선정 후 작성 예정</p>
                )}
              </div>
            )
          })}
        </div>
      </FadeIn>
    )}

    {/* 아이디어 보드 */}
    <FadeIn delay={0.2} direction="up" className="w-full">
      <div class="mb-8">
        <p class="text-xs font-bold tracking-[0.2em] uppercase text-primary mb-2">Community Board</p>
        <h2 class="text-2xl md:text-3xl font-heading font-black text-gray-900 dark:text-white">아이디어 보드</h2>
        <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">투표는 24시간 1회 · 아이디어 제안은 1시간 1회</p>
      </div>
      <SeedlingBoard client:load />
    </FadeIn>

  </main>
</BaseLayout>
