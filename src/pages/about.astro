---
import BaseLayout from '../layouts/BaseLayout.astro'
import FadeIn from '../components/FadeIn.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog')
const postCount = allPosts.length
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags ?? []))]
const tagCount = allTags.length
const pillars = [
	{
		label: '01',
		title: '자료 확인',
		body: '농지, 보조금, 스마트팜, 태양광 관련 자료를 확인합니다.'
	},
	{
		label: '02',
		title: '쉽게 정리',
		body: '법령, 지원사업, 비용처럼 어려운 내용을 짧고 분명하게 풀어 씁니다.'
	},
	{
		label: '03',
		title: '현실 기준',
		body: '농업인이 실제로 확인해야 할 조건과 숫자를 중심으로 정리합니다.'
	}
]

const topics = ['농지', '스마트팜', '태양광', '보조금', '농업 창업', '농가 수익']
---

<BaseLayout title='소개 | IMUN.FARM' description='농업인을 위한 지식블로그 IMUN.FARM 소개'>
	<section class='about-hero'>
		<FadeIn direction='up'>
			<p class='eyebrow'>ABOUT</p>
			<h1>농업인을 위한<br />지식블로그입니다.</h1>
			<p class='lead'>
				농지, 스마트팜, 태양광, 보조금처럼 농업인이 자주 찾는 정보를 쉽게 정리합니다. 복잡한 말보다
				바로 이해되는 글을 목표로 합니다.
			</p>
		</FadeIn>
	</section>

	<section class='about-loop'>
		<div class='loop-heading'>
			<FadeIn direction='up'>
				<p class='eyebrow'>HOW WE WRITE</p>
				<h2>읽기 쉽게 정리합니다.</h2>
			</FadeIn>
		</div>
		<div class='pillar-grid'>
			{
				pillars.map((item, index) => (
					<FadeIn delay={index * 0.08} direction='up'>
						<article class='pillar-card'>
							<span>{item.label}</span>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					</FadeIn>
				))
			}
		</div>
	</section>

	<section class='about-topics'>
		<div>
			<FadeIn direction='up'>
				<p class='eyebrow'>TOPICS</p>
				<h2>주로 다루는 주제</h2>
				<p>농업인이 검색하는 주제를 기준으로 글을 묶습니다.</p>
			</FadeIn>
		</div>
		<div class='topic-cloud' aria-label='IMUN.FARM topics'>
			{topics.map((topic) => <span>{topic}</span>)}
		</div>
	</section>

	<section class='about-metrics'>
		<FadeIn direction='up'>
			<div class='metric-card'>
				<strong>{postCount}</strong>
				<span>published posts</span>
			</div>
		</FadeIn>
		<FadeIn delay={0.08} direction='up'>
			<div class='metric-card'>
				<strong>{tagCount}</strong>
				<span>tags</span>
			</div>
		</FadeIn>
		<FadeIn delay={0.16} direction='up'>
			<div class='metric-card'>
				<strong>01</strong>
				<span>blog</span>
			</div>
		</FadeIn>
	</section>

	<section class='about-cta'>
		<FadeIn direction='up'>
			<h2>문의할 내용이 있다면</h2>
			<p>글 제안, 제보, 협찬 문의를 메일로 보내주세요.</p>
			<a href='/contact'>협찬문의 →</a>
		</FadeIn>
	</section>
</BaseLayout>

<style>
	.about-hero,
	.about-loop,
	.about-topics,
	.about-metrics,
	.about-cta {
		position: relative;
		z-index: 1;
		width: min(1180px, calc(100vw - 48px));
		margin-inline: auto;
	}

	.about-hero {
		display: grid;
		min-height: 82dvh;
		place-items: center;
		padding: 8rem 0 5rem;
		text-align: center;
	}

	.eyebrow {
		margin: 0 0 1rem;
		color: #6ae4ff;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	.about-hero h1 {
		color: #f6f7fb;
		font-size: clamp(54px, 8.6vw, 118px);
		font-weight: 880;
		line-height: 0.95;
		letter-spacing: -0.075em;
		text-wrap: balance;
	}

	.lead {
		max-width: 820px;
		margin: 2rem auto 0;
		color: rgba(246, 247, 251, 0.68);
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.5;
	}

	.about-loop,
	.about-topics,
	.about-metrics,
	.about-cta {
		padding: clamp(5rem, 10vw, 9rem) 0;
	}

	.loop-heading {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	.loop-heading h2,
	.about-topics h2,
	.about-cta h2 {
		color: #f6f7fb;
		font-size: clamp(42px, 6.2vw, 86px);
		font-weight: 820;
		line-height: 0.98;
		letter-spacing: -0.06em;
		text-wrap: balance;
	}

	.pillar-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.pillar-card,
	.metric-card {
		min-height: 270px;
		border: 1px solid rgba(246, 247, 251, 0.1);
		border-radius: 2rem;
		background: rgba(246, 247, 251, 0.045);
		padding: 1.6rem;
		backdrop-filter: blur(4px);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			background 220ms ease;
	}

	.pillar-card:hover,
	.metric-card:hover {
		transform: translateY(-4px);
		border-color: rgba(106, 228, 255, 0.34);
		background: rgba(246, 247, 251, 0.07);
	}

	.pillar-card span {
		color: #6ae4ff;
		font-size: 14px;
		font-weight: 800;
	}

	.pillar-card h3 {
		margin-top: 3rem;
		color: #f6f7fb;
		font-size: clamp(28px, 3.6vw, 48px);
		font-weight: 760;
		letter-spacing: -0.045em;
	}

	.pillar-card p,
	.about-topics p,
	.about-cta p {
		margin-top: 1rem;
		color: rgba(246, 247, 251, 0.64);
		font-size: 18px;
		line-height: 1.55;
	}

	.about-topics {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(320px, 1fr);
		gap: clamp(2rem, 6vw, 5rem);
		align-items: center;
	}

	.topic-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.topic-cloud span {
		display: inline-flex;
		border: 1px solid rgba(246, 247, 251, 0.12);
		border-radius: 999px;
		background: rgba(246, 247, 251, 0.04);
		color: rgba(246, 247, 251, 0.76);
		padding: 0.9rem 1.15rem;
		font-size: clamp(18px, 2.4vw, 34px);
		font-weight: 760;
		letter-spacing: -0.04em;
	}

	.about-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.metric-card strong {
		display: block;
		color: #f6f7fb;
		font-size: clamp(62px, 9vw, 132px);
		font-weight: 880;
		line-height: 0.85;
		letter-spacing: -0.08em;
	}

	.metric-card span {
		display: block;
		margin-top: 1rem;
		color: rgba(246, 247, 251, 0.52);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.about-cta {
		text-align: center;
	}

	.about-cta a {
		display: inline-flex;
		margin-top: 2rem;
		border-radius: 999px;
		background: #f6f7fb;
		color: #05060a;
		padding: 1rem 1.4rem;
		font-weight: 800;
	}

	@media (max-width: 820px) {
		.pillar-grid,
		.about-topics,
		.about-metrics {
			grid-template-columns: 1fr;
		}
	}
</style>
