---
import BaseLayout from '../layouts/BaseLayout.astro'
import FadeIn from '../components/FadeIn.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog')
const postCount = allPosts.length
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))]
const tagCount = allTags.length
---

<BaseLayout title="소개 | IMUN.FARM" description="IT 지식을 씨앗 삼아 심고, 코드로 물을 주고, 인사이트를 수확하는 이문농장을 소개합니다.">

  <!-- ===================== -->
  <!-- HERO: Full-Bleed Farm -->
  <!-- ===================== -->
  <div class="relative h-screen min-h-[700px] flex items-end justify-start overflow-hidden">
    <div class="absolute inset-0 z-0 bg-[#070d09]">
      <img src="/images/digital-garden-hero.png" alt="IMUN.FARM" class="w-full h-full object-cover opacity-70 mix-blend-luminosity" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#070d09] via-[#070d09]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#070d09]/80 to-transparent"></div>
    </div>

    <div class="relative z-10 px-8 md:px-20 pb-24 max-w-5xl">
      <FadeIn delay={0.1} direction="up">
        <span class="inline-block px-3 py-1 text-xs font-bold tracking-widest uppercase text-primary border border-primary/30 bg-primary/10 rounded-full mb-6">
          IT Knowledge Farm
        </span>
      </FadeIn>
      <FadeIn delay={0.25} direction="up">
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-black text-white leading-[0.95] tracking-tighter mb-8">
          우리는<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-green-400 to-secondary">IT 지식을</span><br/>
          농사짓습니다.
        </h1>
      </FadeIn>
      <FadeIn delay={0.4} direction="up">
        <p class="text-lg md:text-2xl text-white/70 font-light leading-relaxed max-w-2xl">
          씨앗은 <strong class="text-white">호기심</strong>이고, 비료는 <strong class="text-white">코드</strong>이며,<br class="hidden md:block"/>
          수확물은 누구나 가져갈 수 있는 <strong class="text-primary">인사이트</strong>입니다.
        </p>
      </FadeIn>
    </div>
  </div>

  <!-- ===================== -->
  <!-- 농사 사이클: 파종 → 재배 → 수확 -->
  <!-- ===================== -->
  <section class="bg-gray-950 text-white py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <FadeIn direction="up">
        <div class="text-center mb-24">
          <h2 class="text-4xl md:text-5xl font-heading font-black mb-4" style="color: white !important;">
            IMUN.FARM <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">농사 사이클</span>
          </h2>
          <p class="text-lg max-w-xl mx-auto" style="color: rgba(255,255,255,0.85) !important;">
            진짜 농장의 사계절처럼, 이곳도 끊임없는 순환 속에 지식이 자라납니다.
          </p>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative">
        <!-- Connecting line -->
        <div class="absolute top-24 left-1/6 right-1/6 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent hidden md:block"></div>

        <!-- 1. 파종 -->
        <FadeIn delay={0.1} direction="up">
          <div class="relative flex flex-col items-center text-center p-10 group">
            <div class="relative mb-8">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary/20 to-primary/5 border border-primary/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500 shadow-[0_0_30px_rgba(34,197,94,0.15)]">
                🌱
              </div>
              <span class="absolute -top-2 -right-2 w-7 h-7 bg-primary text-white text-xs font-black rounded-full flex items-center justify-center shadow-lg">01</span>
            </div>
            <h3 class="text-2xl font-heading font-black mb-3" style="color: white !important;">파종 (씨앗 수집)</h3>
            <p class="leading-relaxed" style="color: rgba(255,255,255,0.85) !important;">
              해외 기술 블로그, 논문, GitHub 트렌드를 순찰하며
              <strong class="text-white">아직 국내에 알려지지 않은 기술의 씨앗</strong>을 발굴합니다.
            </p>
          </div>
        </FadeIn>

        <!-- 2. 재배 -->
        <FadeIn delay={0.25} direction="up">
          <div class="relative flex flex-col items-center text-center p-10 group">
            <div class="relative mb-8">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-secondary/20 to-secondary/5 border border-secondary/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500 shadow-[0_0_30px_rgba(231,111,81,0.15)]">
                💻
              </div>
              <span class="absolute -top-2 -right-2 w-7 h-7 bg-secondary text-white text-xs font-black rounded-full flex items-center justify-center shadow-lg">02</span>
            </div>
            <h3 class="text-2xl font-heading font-black mb-3" style="color: white !important;">재배 (직접 실험)</h3>
            <p class="leading-relaxed" style="color: rgba(255,255,255,0.85) !important;">
              발굴한 기술을 <strong class="text-white">직접 손으로 짜고 실험</strong>합니다.
              삽질하고 디버깅하며 진짜 이해를 만들어갑니다.
            </p>
          </div>
        </FadeIn>

        <!-- 3. 수확 -->
        <FadeIn delay={0.4} direction="up">
          <div class="relative flex flex-col items-center text-center p-10 group">
            <div class="relative mb-8">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-500/20 to-blue-500/5 border border-blue-500/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500 shadow-[0_0_30px_rgba(59,130,246,0.15)]">
                📦
              </div>
              <span class="absolute -top-2 -right-2 w-7 h-7 bg-blue-500 text-white text-xs font-black rounded-full flex items-center justify-center shadow-lg">03</span>
            </div>
            <h3 class="text-2xl font-heading font-black mb-3" style="color: white !important;">수확 (글로 정리)</h3>
            <p class="leading-relaxed" style="color: rgba(255,255,255,0.85) !important;">
              실험의 결과를 <strong class="text-white">말하듯 쉽게 쓴 글</strong>로 포장해
              이 농장 곳곳에 가져다 놓습니다. 무료입니다.
            </p>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- 재배 중인 작물 (주요 주제들) -->
  <!-- ===================== -->
  <section class="py-32 px-6 bg-bg-light dark:bg-[#0a0f0d]">
    <div class="max-w-7xl mx-auto">
      <FadeIn direction="up">
        <div class="mb-16">
          <span class="text-primary font-bold tracking-widest uppercase text-sm">지금 밭에서 자라는 것들</span>
          <h2 class="text-4xl md:text-5xl font-heading font-black mt-2 text-gray-900 dark:text-white">
            현재 재배 중인 작물
          </h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- AI/ML -->
        <FadeIn delay={0.1} direction="up">
          <div class="relative overflow-hidden rounded-3xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-8 group hover:border-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-primary/5 hover:-translate-y-1">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-primary/10 to-transparent rounded-full blur-3xl group-hover:w-60 group-hover:h-60 transition-all duration-700"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-green-600 flex items-center justify-center shadow-lg shadow-primary/30">
                  <span class="text-white text-xl font-black">AI</span>
                </div>
                <div>
                  <h3 class="text-xl font-heading font-black text-gray-900 dark:text-white">AI / 머신러닝</h3>
                  <span class="text-xs text-primary font-bold tracking-wide">🌿 성장 중</span>
                </div>
              </div>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                LLM 파인튜닝부터 RAG 아키텍처, AI 에이전트 설계까지. 실제 프로덕트에 AI를 이식하는 과정을 실험하고 기록합니다.
              </p>
            </div>
          </div>
        </FadeIn>

        <!-- IT 트렌드 분석 -->
        <FadeIn delay={0.2} direction="up">
          <div class="relative overflow-hidden rounded-3xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-8 group hover:border-secondary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-secondary/5 hover:-translate-y-1">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-secondary/10 to-transparent rounded-full blur-3xl group-hover:w-60 group-hover:h-60 transition-all duration-700"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-secondary to-orange-600 flex items-center justify-center shadow-lg shadow-secondary/30">
                  <span class="text-white text-xl font-black">&#128202;</span>
                </div>
                <div>
                  <h3 class="text-xl font-heading font-black text-gray-900 dark:text-white">IT 트렌드 분석</h3>
                  <span class="text-xs text-secondary font-bold tracking-wide">수확 완료</span>
                </div>
              </div>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                매일 쏟아지는 기술 뉴스 중 진짜 중요한 것을 선별합니다. 단순 요약이 아닌 <strong>실제 의미와 파급력</strong> 중심의 해설을 제공합니다.
              </p>
            </div>
          </div>
        </FadeIn>

        <!-- 웹 개발 -->
        <FadeIn delay={0.3} direction="up">
          <div class="relative overflow-hidden rounded-3xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-8 group hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-500/5 hover:-translate-y-1">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-blue-500/10 to-transparent rounded-full blur-3xl group-hover:w-60 group-hover:h-60 transition-all duration-700"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center shadow-lg shadow-blue-500/30">
                  <span class="text-white text-xl font-black">&lt;/&gt;</span>
                </div>
                <div>
                  <h3 class="text-xl font-heading font-black text-gray-900 dark:text-white">모던 웹 개발</h3>
                  <span class="text-xs text-blue-500 font-bold tracking-wide">🌱 싹 트는 중</span>
                </div>
              </div>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Astro, React, TypeScript를 주요 농기구로 사용합니다. 성능 최적화와 DX(개발자 경험) 개선에 대한 집착을 가감 없이 씁니다.
              </p>
            </div>
          </div>
        </FadeIn>

        <!-- 개발 도구 & 자동화 -->
        <FadeIn delay={0.4} direction="up">
          <div class="relative overflow-hidden rounded-3xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-8 group hover:border-purple-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-purple-500/5 hover:-translate-y-1">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl group-hover:w-60 group-hover:h-60 transition-all duration-700"></div>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-fuchsia-600 flex items-center justify-center shadow-lg shadow-purple-500/30">
                  <span class="text-white text-xl font-black">⚙️</span>
                </div>
                <div>
                  <h3 class="text-xl font-heading font-black text-gray-900 dark:text-white">자동화 & DevOps</h3>
                  <span class="text-xs text-purple-500 font-bold tracking-wide">🌿 성장 중</span>
                </div>
              </div>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                귀찮은 건 다 기계한테 시키는 게 진짜 농부의 지혜. CI/CD 파이프라인, Docker, 셸 스크립트 자동화를 집착적으로 다룹니다.
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>



  <!-- ===================== -->
  <!-- HARVEST STATS -->
  <!-- ===================== -->
  <section class="relative py-32 px-6 overflow-hidden bg-gray-950">
    <div class="absolute inset-0">
      <img src="/images/ideas-hero-bg.png" alt="" class="w-full h-full object-cover opacity-10" />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-950/80 to-gray-950"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto text-center">
      <FadeIn direction="up">
        <h2 class="text-4xl md:text-5xl font-heading font-black mb-4" style="color: white !important;">수확 현황</h2>
        <p class="mb-20 text-lg" style="color: rgba(255,255,255,0.80) !important;">농장의 현재 성장 지표입니다</p>
      </FadeIn>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <FadeIn delay={0.1} direction="up">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-black text-primary mb-2">{postCount}</div>
            <div class="text-sm uppercase tracking-widest font-medium" style="color: rgba(255,255,255,0.80) !important;">누적 포스트</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.2} direction="up">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-black text-secondary mb-2">{tagCount}</div>
            <div class="text-sm uppercase tracking-widest font-medium" style="color: rgba(255,255,255,0.80) !important;">기술 태그</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.3} direction="up">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-black text-blue-400 mb-2">100%</div>
            <div class="text-sm uppercase tracking-widest font-medium" style="color: rgba(255,255,255,0.80) !important;">무료 콘텐츠</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.4} direction="up">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-black text-purple-400 mb-2">∞</div>
            <div class="text-sm uppercase tracking-widest font-medium" style="color: rgba(255,255,255,0.80) !important;">배움의 순환</div>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- ===================== -->
  <!-- CTA -->
  <!-- ===================== -->
  <section class="py-32 px-6 bg-bg-light dark:bg-[#0a0f0d] text-center">
    <FadeIn direction="up">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-heading font-black mb-6 text-gray-900 dark:text-white">
          아이디어가 있거나<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">협업을 원하신다면</span>
        </h2>
        <p class="text-gray-500 dark:text-gray-400 text-lg mb-10">
          콘텐츠 제안, 기술 협업, 스폰서십 — 어떤 형태의 연결도 환영합니다.
        </p>
        <a href="/contact" class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-bold text-white bg-primary rounded-full hover:bg-primary-dark hover:scale-105 transition-all shadow-xl shadow-primary/30">
          <span>연락하기</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </FadeIn>
  </section>

</BaseLayout>
