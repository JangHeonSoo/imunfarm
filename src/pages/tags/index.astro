---
import BaseLayout from '@/layouts/BaseLayout'
import FadeIn from '../../components/FadeIn.astro'
import { getPosts } from '@/utils'

const posts = await getPosts()
const tagCounts = new Map<string, number>()

posts.forEach((post) => {
	post.data.tags?.forEach((tag) => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1)
	})
})

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1])
const maxCount = Math.max(...Array.from(tagCounts.values()))
const minCount = Math.min(...Array.from(tagCounts.values()))

const getFontSize = (count: number) => {
	if (maxCount === minCount) return 32
	const ratio = (count - minCount) / (maxCount - minCount)
	return Math.round(16 + ratio * 46)
}

const getTone = (count: number) => {
	if (maxCount === minCount) return 1
	return (count - minCount) / (maxCount - minCount)
}
---

<BaseLayout title='Tags'>
	<section class='tags-hero'>
		<FadeIn direction='up'>
			<p class='eyebrow'>TAGS</p>
			<h1>주제별로<br />글을 모았습니다.</h1>
			<p class='lead'>
				농지, 스마트팜, 태양광, 보조금 같은 주제를 태그로 모았습니다. 필요한 주제를 눌러 관련 글을
				확인하세요.
			</p>
		</FadeIn>
	</section>

	<section class='tag-board'>
		<div class='tag-board-heading'>
			<p class='eyebrow'>TAG LIST</p>
			<h2>{sortedTags.length}개의 태그</h2>
			<p>{posts.length}개의 글을 주제별로 찾아볼 수 있습니다.</p>
		</div>
		<div class='tag-cloud' id='tag-cloud'>
			{
				sortedTags.map(([tag, count], index) => {
					const size = getFontSize(count)
					const tone = getTone(count)
					const isLarge = tone > 0.46
					return (
						<a
							href={`/tags/${tag.toLowerCase()}`}
							class={`tag-item ${isLarge ? 'is-large' : ''}`}
							style={`--size:${size}px; --tone:${tone}; --delay:${(index % 9) * 0.08}s`}
							data-tag={tag.toLowerCase()}
							title={`${count} posts`}
						>
							#{tag}
						</a>
					)
				})
			}
		</div>
	</section>

	<section class='tag-stats'>
		<div>
			<strong>{sortedTags.length}</strong>
			<span>tags</span>
		</div>
		<div>
			<strong>{posts.length}</strong>
			<span>posts</span>
		</div>
		<div>
			<strong>#{sortedTags[0]?.[0] || '없음'}</strong>
			<span>most used</span>
		</div>
	</section>
</BaseLayout>

<script>
	const tagItems = document.querySelectorAll('.tag-item') as NodeListOf<HTMLElement>
	tagItems.forEach((item) => {
		item.addEventListener('mouseenter', () => (item.style.filter = 'brightness(1.25)'))
		item.addEventListener('mouseleave', () => (item.style.filter = ''))
	})
</script>

<style>
	.tags-hero,
	.tag-board,
	.tag-stats {
		position: relative;
		z-index: 1;
		width: min(1180px, calc(100vw - 48px));
		margin-inline: auto;
	}

	.tags-hero {
		display: grid;
		min-height: 72dvh;
		place-items: center;
		padding: 8rem 0 4rem;
		text-align: center;
	}

	.eyebrow {
		margin: 0 0 1rem;
		color: #6ae4ff;
		font-size: 13px;
		font-weight: 850;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		margin: 0;
	}

	.tags-hero h1 {
		color: #f6f7fb;
		font-size: clamp(58px, 9vw, 126px);
		font-weight: 890;
		line-height: 0.92;
		letter-spacing: -0.085em;
		text-wrap: balance;
	}

	.lead {
		max-width: 760px;
		margin: 2rem auto 0;
		color: rgba(246, 247, 251, 0.68);
		font-size: clamp(18px, 2vw, 23px);
		line-height: 1.5;
	}

	.tag-board {
		border: 1px solid rgba(246, 247, 251, 0.1);
		border-radius: 2rem;
		background: rgba(246, 247, 251, 0.045);
		padding: clamp(1.5rem, 4vw, 3rem);
		backdrop-filter: blur(4px);
	}

	.tag-board-heading {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(320px, 1fr);
		gap: 2rem;
		align-items: end;
		margin-bottom: 3rem;
	}

	.tag-board-heading h2 {
		color: #f6f7fb;
		font-size: clamp(38px, 5vw, 74px);
		font-weight: 850;
		line-height: 0.95;
		letter-spacing: -0.07em;
	}

	.tag-board-heading p {
		color: rgba(246, 247, 251, 0.62);
		font-size: 18px;
		line-height: 1.5;
	}

	.tag-cloud {
		display: flex;
		min-height: 720px;
		align-content: center;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1.2rem 1.6rem;
	}

	.tag-item {
		display: inline-flex;
		color: rgba(246, 247, 251, calc(0.32 + var(--tone) * 0.46));
		font-size: var(--size);
		font-weight: 650;
		letter-spacing: -0.045em;
		line-height: 1;
		animation: float-tag 4.2s ease-in-out infinite;
		animation-delay: var(--delay);
		transition:
			transform 220ms ease,
			color 220ms ease,
			filter 220ms ease;
	}

	.tag-item.is-large {
		color: #6ae4ff;
		font-weight: 850;
		text-shadow: 0 0 30px rgba(106, 228, 255, 0.12);
	}

	.tag-item:hover {
		color: #f6f7fb;
		transform: translateY(-6px) scale(1.04);
	}

	.tag-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		padding: clamp(4rem, 8vw, 8rem) 0;
	}

	.tag-stats div {
		min-height: 210px;
		border: 1px solid rgba(246, 247, 251, 0.1);
		border-radius: 2rem;
		background: rgba(246, 247, 251, 0.045);
		padding: 1.5rem;
	}

	.tag-stats strong {
		display: block;
		color: #f6f7fb;
		font-size: clamp(38px, 5vw, 72px);
		font-weight: 850;
		line-height: 0.95;
		letter-spacing: -0.06em;
	}

	.tag-stats span {
		display: block;
		margin-top: 1rem;
		color: rgba(246, 247, 251, 0.5);
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	@keyframes float-tag {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-8px);
		}
	}

	@media (max-width: 860px) {
		.tag-board-heading,
		.tag-stats {
			grid-template-columns: 1fr;
		}
		.tag-cloud {
			min-height: auto;
		}
	}
</style>
