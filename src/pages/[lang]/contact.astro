---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FadeIn from '../../components/FadeIn.astro'
import { SUPPORTED_LOCALES, DEFAULT_LOCALE } from '@/utils'

export async function getStaticPaths() {
	return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }))
}

const locale = Astro.params.lang ?? DEFAULT_LOCALE
const isEn = locale === 'en'
const types = isEn
	? [
			['Content Proposal', 'Send topics, corrections, field questions, or article ideas.'],
			['Tech Collaboration', 'We can review smart farm, farm data, and automation topics.'],
			['Sponsorship', 'We can introduce agriculture, technology, or energy products.'],
			['Tips and corrections', 'Send sources, field cases, corrections, or article ideas.']
		]
	: [
			['콘텐츠 제안', '다뤘으면 하는 주제, 보완이 필요한 글, 현장에서 궁금한 질문을 보내주세요.'],
			['기술 협업', '스마트팜, 농업 데이터, 자동화 관련 내용을 함께 검토합니다.'],
			['협찬 문의', '농업, 기술, 에너지 관련 제품이나 서비스를 소개할 수 있습니다.'],
			['제보', '자료, 보도자료, 현장 사례, 수정할 내용을 보내주세요.']
		]
const steps = isEn
	? ['Inquiry', 'Review', 'Direction', 'Start']
	: ['문의 접수', '내용 검토', '방향 협의', '협업 시작']
---

<BaseLayout
	title={isEn ? 'Contact | IMUN.FARM' : '협찬문의 | IMUN.FARM'}
	description='IMUN.FARM collaboration inquiry'
>
	<section class='contact-hero'>
		<FadeIn direction='up'>
			<p class='eyebrow'>CONTACT</p><h1
				set:html={isEn ? 'Send inquiries<br />by email.' : '문의는<br />메일로 보내주세요.'}
			/><p class='lead'>
				{
					isEn
						? 'Send article ideas, corrections, sponsorship inquiries, or collaboration requests.'
						: '글 제안, 제보, 협찬 문의를 받습니다. 내용과 연락처를 함께 보내주세요.'
				}
			</p><a class='mail-button' href='mailto:denosinfo@gmail.com'>denosinfo@gmail.com →</a>
		</FadeIn>
	</section>
	<section class='contact-grid'>
		{
			types.map(([title, body], i) => (
				<article class='contact-card'>
					<>
						<span>0{i + 1}</span>
						<h2>{title}</h2>
						<p>{body}</p>
					</>
				</article>
			))
		}
	</section>
	<section class='process-section'>
		<div class='process-heading'>
			<p class='eyebrow'>PROCESS</p><h2>
				{isEn ? 'We check and reply.' : '확인 후 답변드립니다.'}
			</h2>
		</div><div class='step-row'>
			{
				steps.map((step, i) => (
					<div class='step-card'>
						<>
							<strong>{i + 1}</strong>
							<span>{step}</span>
						</>
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.contact-hero,
	.contact-grid,
	.process-section {
		position: relative;
		z-index: 1;
		width: min(1180px, calc(100vw - 48px));
		margin-inline: auto;
	}
	.contact-hero {
		display: grid;
		min-height: 82dvh;
		place-items: center;
		padding: 8rem 0 5rem;
		text-align: center;
	}
	.eyebrow {
		margin: 0 0 1rem;
		color: #6ae4ff;
		font-size: 13px;
		font-weight: 850;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}
	h1,
	h2,
	p {
		margin: 0;
	}
	.contact-hero h1 {
		color: #f6f7fb;
		font-size: clamp(56px, 8.8vw, 122px);
		font-weight: 880;
		line-height: 0.94;
		letter-spacing: -0.08em;
	}
	.lead {
		max-width: 790px;
		margin: 2rem auto 0;
		color: rgba(246, 247, 251, 0.68);
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.5;
	}
	.mail-button {
		display: inline-flex;
		margin-top: 2.2rem;
		border-radius: 999px;
		background: #f6f7fb;
		color: #05060a;
		padding: 1rem 1.35rem;
		font-weight: 850;
	}
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		padding: clamp(4rem, 8vw, 8rem) 0;
	}
	.contact-card,
	.step-card {
		border: 1px solid rgba(246, 247, 251, 0.1);
		border-radius: 2rem;
		background: rgba(246, 247, 251, 0.045);
		backdrop-filter: blur(4px);
		transition:
			transform 0.22s ease,
			border-color 0.22s ease,
			background 0.22s ease;
	}
	.contact-card:hover,
	.step-card:hover {
		transform: translateY(-4px);
		border-color: rgba(106, 228, 255, 0.34);
		background: rgba(246, 247, 251, 0.07);
	}
	.contact-card {
		min-height: 270px;
		padding: 1.6rem;
	}
	.contact-card span {
		color: #6ae4ff;
		font-weight: 850;
	}
	.contact-card h2 {
		max-width: 10ch;
		margin-top: 3rem;
		color: #f6f7fb;
		font-size: clamp(34px, 5vw, 68px);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.06em;
	}
	.contact-card p {
		margin-top: 1rem;
		color: rgba(246, 247, 251, 0.64);
		font-size: 18px;
		line-height: 1.55;
	}
	.process-section {
		padding: clamp(5rem, 10vw, 9rem) 0;
	}
	.process-heading {
		max-width: 760px;
		margin-bottom: 2rem;
	}
	.process-heading h2 {
		color: #f6f7fb;
		font-size: clamp(42px, 6.2vw, 84px);
		font-weight: 820;
		line-height: 0.98;
		letter-spacing: -0.06em;
	}
	.step-row {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}
	.step-card {
		min-height: 190px;
		padding: 1.4rem;
	}
	.step-card strong {
		display: block;
		color: rgba(246, 247, 251, 0.16);
		font-size: clamp(58px, 8vw, 112px);
		font-weight: 900;
		line-height: 0.8;
		letter-spacing: -0.08em;
	}
	.step-card span {
		display: block;
		margin-top: 2rem;
		color: #f6f7fb;
		font-size: 20px;
		font-weight: 760;
	}
	@media (max-width: 860px) {
		.contact-grid,
		.step-row {
			grid-template-columns: 1fr;
		}
	}
</style>
