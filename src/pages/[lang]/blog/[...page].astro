---
import type { GetStaticPathsOptions, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout'
import Pagination from '@/components/Pagination'
import FadeIn from '../../../components/FadeIn.astro'
import {
	DEFAULT_LOCALE,
	SUPPORTED_LOCALES,
	getLocalePrefix,
	getPosts,
	stripLocaleFromSlug,
	getCategoryTitleFromSlug,
	getCategorySlug
} from '@/utils'

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const localizedPages = await Promise.all(
		SUPPORTED_LOCALES.filter((loc) => loc !== DEFAULT_LOCALE).map(async (locale) => {
			const posts = await getPosts(undefined, locale)
			return paginate(posts, {
				pageSize: 9,
				params: { lang: locale }
			})
		})
	)

	return localizedPages.flat()
}

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> }
const locale = Astro.params.lang ?? DEFAULT_LOCALE
const localePrefix = getLocalePrefix(locale)
const dateLocale = locale === 'en' ? 'en-US' : 'ko-KR'
---

<BaseLayout title='Blog'>
	<!-- Hero Section -->
	<div
		class='relative overflow-hidden rounded-[34px] border border-white/12 bg-white/[0.045] py-20 mb-12 shadow-[0_32px_90px_rgba(0,0,0,0.22)]'
	>
		<div class='absolute inset-0 opacity-20 pattern-grid-lg'></div>
		<div
			class='absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(106,228,255,0.12),transparent_34rem)]'
		>
		</div>
		<div class='max-w-4xl mx-auto px-4 text-center relative z-10'>
			<FadeIn delay={0.1} direction='up'>
				<span
					class='inline-block py-1 px-3 rounded-full border border-[#6ae4ff]/25 bg-[#6ae4ff]/10 text-[#6ae4ff] font-bold text-sm mb-6 tracking-wide uppercase'
				>
					Blog
				</span>
				<h1
					class='text-4xl md:text-6xl font-heading font-black mb-6 text-[#f2f4ea] tracking-[-0.06em]'
				>
					{locale === 'en' ? 'Farm knowledge blog' : '농업 지식블로그'}
				</h1>
				<p class='text-lg text-[#f2f4ea]/70 max-w-2xl mx-auto'>
					{
						locale === 'en'
							? `${page.total} posts about farming, smart farms, and solar power.`
							: `농업 관련 글 ${page.total}개를 모았습니다.`
					}
				</p>
			</FadeIn>
		</div>
	</div>

	<div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20'>
		<!-- Main Content: Posts Grid -->
		<div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20'>
			{
				page.data.map((post, index) => (
					<FadeIn delay={index * 0.1} direction='up'>
						<article class='rounded-[26px] overflow-hidden border border-white/12 bg-white/[0.045] shadow-[0_24px_70px_rgba(0,0,0,0.18)] hover:-translate-y-1 hover:border-[#6ae4ff]/35 hover:bg-white/[0.07] hover:shadow-[0_30px_90px_rgba(0,0,0,0.28)] transition-all duration-300 group flex flex-col h-full'>
							{post.data.heroImage && (
								<a
									href={`${localePrefix}/${post.collection}/${stripLocaleFromSlug(post.slug, locale)}`}
									class='block overflow-hidden h-56 relative'
								>
									<div class='absolute inset-0 bg-black/20 group-hover:bg-black/5 transition-colors z-10' />
									<img
										src={post.data.heroImage}
										alt={post.data.title}
										class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-500'
									/>
									{post.data.category && (
										<div class='absolute top-4 right-4 z-20'>
											<span class='px-3 py-1 border border-white/15 bg-[#070807]/80 text-[#f2f4ea] backdrop-blur text-xs font-bold rounded-full shadow-sm'>
												{getCategoryTitleFromSlug(getCategorySlug(post.data.category), locale)}
											</span>
										</div>
									)}
								</a>
							)}
							<div class='p-6 flex flex-col flex-grow'>
								<div class='flex items-center gap-2 text-xs text-[#f2f4ea]/50 mb-3 font-medium'>
									<time datetime={post.data.pubDate?.toISOString()}>
										{post.data.pubDate?.toLocaleDateString(dateLocale, {
											year: 'numeric',
											month: 'long',
											day: 'numeric'
										})}
									</time>
								</div>

								<h2 class='text-xl font-heading font-bold mb-3 text-[#f6f7fb] group-hover:text-[#6ae4ff] transition-colors leading-tight'>
									<a
										href={`${localePrefix}/${post.collection}/${stripLocaleFromSlug(post.slug, locale)}`}
									>
										{post.data.title}
									</a>
								</h2>

								{post.data.description && (
									<p class='text-sm text-[#f2f4ea]/62 line-clamp-2 mb-6 flex-grow'>
										{post.data.description}
									</p>
								)}

								<div class='flex items-center justify-between pt-4 border-t border-white/10 mt-auto'>
									<a
										href={`${localePrefix}/${post.collection}/${stripLocaleFromSlug(post.slug, locale)}`}
										class='text-sm font-bold text-[#6ae4ff] flex items-center gap-1 group/link'
									>
										{locale === 'en' ? 'Read post' : '글 보기'}{' '}
										<svg
											class='w-4 h-4 group-hover/link:translate-x-1 transition-transform'
											fill='none'
											stroke='currentColor'
											viewBox='0 0 24 24'
										>
											<path
												stroke-linecap='round'
												stroke-linejoin='round'
												stroke-width='2'
												d='M17 8l4 4m0 0l-4 4m4-4H3'
											/>
										</svg>
									</a>
								</div>
							</div>
						</article>
					</FadeIn>
				))
			}
		</div>

		<div class='flex justify-center'>
			<Pagination page={page} />
		</div>
	</div>
</BaseLayout>

<style>
	.pattern-grid-lg {
		background-image: radial-gradient(currentColor 1px, transparent 1px);
		background-size: 24px 24px;
	}
</style>
